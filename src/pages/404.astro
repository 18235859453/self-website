---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到">
  <section class="flex flex-col items-center justify-center text-center py-20 space-y-4">
    <p class="text-6xl font-bold text-[var(--color-muted)]">404</p>
    <h1 class="text-xl font-semibold text-[var(--color-accent)]">页面未找到</h1>
    <p class="text-sm text-[var(--color-muted)] max-w-sm">
      你访问的页面不存在，可能已被移除或地址输入有误。
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-accent)] hover:bg-[var(--color-border)] transition-colors no-underline"
    >
      返回首页
    </a>
  </section>
</BaseLayout>
